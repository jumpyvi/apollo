#-------------- DESKTOP MODIFICATIONS --------------#

[org.gnome.desktop.interface]
accent-color='purple'

[org.gnome.login-screen]
logo='/usr/share/apollo/assets/watermark.svg'

[org.gnome.desktop.background]
picture-uri="file:///usr/share/backgrounds/apollo/apollo-light.png"
picture-uri-dark="file:///usr/share/backgrounds/apollo/apollo-dark.png"

[org.gnome.shell]
always-show-log-out=true